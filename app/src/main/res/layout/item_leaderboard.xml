<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/leaderboardCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:strokeWidth="@dimen/card_stroke_width"
    app:strokeColor="@color/card_stroke_light"
    android:layout_margin="4dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/padding_medium">

        <!-- Rank badge in top-right -->
        <TextView
            android:id="@+id/rankBadge"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:gravity="center"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-bold"
            android:background="@drawable/bg_chip_training"
            android:visibility="visible" />

        <!-- Model name (bold, 14sp) -->
        <TextView
            android:id="@+id/modelName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/rankBadge"
            android:textSize="14sp"
            android:textColor="@color/on_surface_light"
            android:fontFamily="sans-serif-bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Status dot + Generation badge Chip row -->
        <LinearLayout
            android:id="@+id/statusRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/modelName"
            android:layout_alignParentStart="true"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <!-- Animated status dot (8dp circle) -->
            <View
                android:id="@+id/statusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/ic_status_dot" />

            <!-- Generation badge Chip -->
            <TextView
                android:id="@+id/generationBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_caption"
                android:background="@drawable/bg_chip_idle"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="@color/on_surface_variant_light"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- Parent name for clones -->
        <TextView
            android:id="@+id/parentName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/statusRow"
            android:layout_alignParentStart="true"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/on_surface_variant_light"
            android:fontFamily="sans-serif-italic"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />

        <!-- Accuracy % large bold text -->
        <TextView
            android:id="@+id/accuracyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/parentName"
            android:layout_alignParentStart="true"
            android:textSize="22sp"
            android:textColor="@color/accent_indigo"
            android:fontFamily="sans-serif-bold"
            android:layout_marginTop="6dp" />

        <!-- Mini horizontal ProgressBar -->
        <ProgressBar
            android:id="@+id/miniProgressBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_below="@id/accuracyText"
            android:layout_alignParentStart="true"
            android:layout_marginTop="4dp"
            android:progressDrawable="@drawable/bg_progress_accent"
            android:max="100" />

        <!-- Epoch indicator -->
        <TextView
            android:id="@+id/epochIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/miniProgressBar"
            android:layout_alignParentStart="true"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/on_surface_variant_light"
            android:layout_marginTop="2dp" />

        <!-- Status label -->
        <TextView
            android:id="@+id/statusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/miniProgressBar"
            android:layout_alignParentEnd="true"
            android:textSize="@dimen/text_caption"
            android:background="@drawable/bg_chip_idle"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textColor="@color/on_surface_variant_light"
            android:layout_marginTop="2dp" />

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>
