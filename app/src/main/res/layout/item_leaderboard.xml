<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/leaderboardCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:strokeWidth="@dimen/card_stroke_width"
    app:strokeColor="@color/card_stroke_light"
    android:layout_marginBottom="@dimen/margin_small">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/padding_medium">

        <ImageView
            android:id="@+id/rankIcon"
            android:layout_width="@dimen/icon_size_medium"
            android:layout_height="@dimen/icon_size_medium"
            android:contentDescription="Rank" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/margin_small">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/modelName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/on_surface_light"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <ImageView
                    android:id="@+id/crownIcon"
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:src="@drawable/ic_crown"
                    android:visibility="gone"
                    android:contentDescription="Best" />

                <ImageView
                    android:id="@+id/skullIcon"
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:src="@drawable/ic_skull"
                    android:visibility="gone"
                    android:contentDescription="Eliminated" />
            </LinearLayout>

            <TextView
                android:id="@+id/generationBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_caption"
                android:background="@drawable/bg_chip_idle"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="@color/on_surface_variant_light"
                android:layout_marginTop="2dp" />

            <ProgressBar
                android:id="@+id/miniProgressBar"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="4dp"
                android:max="100" />
        </LinearLayout>

        <TextView
            android:id="@+id/accuracyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_title"
            android:textColor="@color/accent_indigo"
            android:fontFamily="sans-serif-medium"
            android:minWidth="64dp"
            android:gravity="end" />

        <ImageView
            android:id="@+id/lineageIcon"
            android:layout_width="@dimen/icon_size_small"
            android:layout_height="@dimen/icon_size_small"
            android:src="@drawable/ic_lineage"
            android:layout_marginStart="@dimen/margin_small"
            android:contentDescription="Lineage" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
