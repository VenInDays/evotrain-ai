<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/import_dataset"
                android:textSize="@dimen/text_heading"
                android:textColor="@color/on_surface_light"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="@dimen/margin_medium" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/importAreaCard"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:cardCornerRadius="@dimen/corner_radius_large"
                app:cardElevation="@dimen/card_elevation"
                app:strokeWidth="@dimen/card_stroke_width"
                app:strokeColor="@color/accent_indigo"
                android:layout_marginBottom="@dimen/margin_medium">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="@dimen/padding_large">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_train"
                        android:contentDescription="@string/import_dataset"
                        android:layout_marginBottom="@dimen/margin_small"
                        app:tint="@color/accent_indigo" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/select_zip_file"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/on_surface_variant_light" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectZip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/select_zip_file"
                        android:layout_marginTop="@dimen/margin_small"
                        app:cornerRadius="@dimen/corner_radius" />

                    <ProgressBar
                        android:id="@+id/unzipProgress"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:visibility="gone"
                        android:layout_marginTop="@dimen/margin_small" />

                    <TextView
                        android:id="@+id/unzipStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/on_surface_variant_light"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/datasetSummaryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:strokeWidth="@dimen/card_stroke_width"
                app:strokeColor="@color/card_stroke_light"
                android:visibility="gone"
                android:layout_marginBottom="@dimen/margin_medium">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dataset_summary"
                        android:textSize="@dimen/text_title"
                        android:textColor="@color/on_surface_light"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="@dimen/margin_small" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/margin_small">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/likeCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="32sp"
                                android:textColor="@color/soft_emerald"
                                android:fontFamily="sans-serif-bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/like_images"
                                android:textSize="@dimen/text_caption"
                                android:textColor="@color/on_surface_variant_light" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/nonlikeCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="32sp"
                                android:textColor="@color/rose"
                                android:fontFamily="sans-serif-bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/nonlike_images"
                                android:textSize="@dimen/text_caption"
                                android:textColor="@color/on_surface_variant_light" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/warningText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/warning_min_images"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/muted_amber"
                        android:visibility="gone"
                        android:layout_marginBottom="@dimen/margin_small" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sample_preview"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/on_surface_light"
                        android:layout_marginTop="@dimen/margin_small" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/previewRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_small"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartTraining"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/start_training"
                app:cornerRadius="@dimen/corner_radius"
                android:visibility="gone"
                android:layout_marginBottom="@dimen/margin_small" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStopTraining"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/stop_training"
                app:cornerRadius="@dimen/corner_radius"
                android:backgroundTint="@color/rose"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Test AI FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabTestAi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/padding_medium"
        android:contentDescription="@string/test_ai_title"
        android:src="@drawable/ic_train"
        app:backgroundTint="@color/soft_emerald"
        app:tint="@color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
